AddOptionMenu "OptionsMenu"
{
    Submenu "$PBXCore_Settings", "PB_AddonOptions"
}
AddOptionMenu "OptionsMenuSimple"
{
	Submenu "$PBXCore_Settings", "PB_AddonOptions"
}
ListMenu "MainMenu"
{
	Font		"PBBIG",	"red",	"white"
	StaticPatch	160, -2,	"M_DOOMPB",	1
	Position	85, 66
	TextItem	"New Game",	"n",	"PlayerclassMenu"
	Selector	"M_SKULL1",	-30, -8
	ifOption(SwapMenu)
	{
		TextItem "Load Game",			"l",	"LoadGameMenu"
		TextItem "Save Game",			"s",	"SaveGameMenu"
		TextItem "Options",				"o",	"OptionsMenu"
		TextItem "Project Brutality",	"p",	"PBSettings"
		TextItem "PB Extended",	        "p",	"PB_AddonOptions"
	}
	else
	{
		TextItem "Options",				"o",	"OptionsMenu"
		TextItem "Project Brutality",	"p",	"PBSettings"
		TextItem "PB Extended",	        "p",	"PB_AddonOptions"
		TextItem "Load Game",			"l",	"LoadGameMenu"
		TextItem "Save Game",			"s",	"SaveGameMenu"
	}
	ifOption(ReadThis)
	{
		TextItem "Read This!","r",	"ReadThisMenu"
	}
	TextItem "Quit Game",	"q",	"QuitMenu"
	Size Clean
}


AddOptionMenu "PB_AddonOptions"
{
    Submenu "$PBXCore_Settings", "PBXCore_Menu"
    Submenu "$PBXHud_Settings", "PBXHud_Menu"
}

OptionMenu "PBXCore_Menu"
{
    Title "$PBXCore_Settings"
	Class "PB_OptionMenu"
    Position	-48
    StaticText	"--------- PBX Core Settings ---------", 1
    Option  "Print PBX Versions", "PBXCore_PrintVersion", "OnOff"
    Option  "Enable Tooltips", "PBXCore_SendTip", "OnOff"
    StaticText " "
    StaticText	"--------- PBX HUD Settings ---------", 1
    SafeCommand  "Reset Weapon HUD to Default", "resetcvar PBXWeapons_Weaponhud_x; resetcvar PBXWeapons_Weaponhud_y; resetcvar PBXWeapons_Weaponhud_scale; resetcvar PBXWeapons_Weaponhud_alpha; resetcvar PBXWeapons_Weaponhud_boxW; resetcvar PBXWeapons_Weaponhud_boxH"
    SafeCommand  "Reset Weapon Mode HUD to Default", "resetcvar PBXWeapons_WeaponModehud_x; resetcvar PBXWeapons_WeaponModehud_y; resetcvar PBXWeapons_WeaponModehud_scale; resetcvar PBXWeapons_WeaponModehud_alpha; resetcvar PBXWeapons_WeaponModehud_boxW; resetcvar PBXWeapons_WeaponModehud_boxH"
    SafeCommand  "Reset Armor HUD to Default", "resetcvar PBXWeapons_Armorhud_x; resetcvar PBXWeapons_Armorhud_y; resetcvar PBXWeapons_Armorhud_scale; resetcvar PBXWeapons_Armorhud_alpha; resetcvar PBXWeapons_Armorhud_boxW; resetcvar PBXWeapons_Armorhud_boxH"
    StaticText "$PBXCore_Version",cyan
    StaticText " "
}

