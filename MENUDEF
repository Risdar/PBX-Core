AddOptionMenu "PB_AddonOptions"
{
    Submenu "$PBXHud_Settings", "PBXHud_Menu"
}
OptionMenu "PBXHud_Menu"
{
    Title "$PBXHud_Settings"
	Class "PB_OptionMenu"

    StaticText "PBX HUD Settings", grey
    StaticText " "
    FlagOption "Weapon HUD",            "PBXWeapons_hudsetting_filter",    "OffOn", 0
    Slider     "Horizontal (X)",        "PBXWeapons_Weaponhud_x",          -700, 700, 1
    Slider     "Vertical (Y)",          "PBXWeapons_Weaponhud_y",          -700, 700, 1
    Slider     "Scale",                 "PBXWeapons_Weaponhud_scale",      0.1, 10, 0.1
    Slider     "Transparency",	        "PBXWeapons_Weaponhud_alpha",      0, 1, 0.02, 2
    StaticText " "
    StaticText "Weapon Mode HUD"
    Slider     "Horizontal (X)",        "PBXWeapons_WeaponModehud_x",      -700, 700, 1
    Slider     "Vertical (Y)",          "PBXWeapons_WeaponModehud_y",      -700, 700, 1
    Slider     "Scale",                 "PBXWeapons_WeaponModehud_scale",  0.1, 10, 0.1
    Slider     "Transparency",	        "PBXWeapons_WeaponModehud_alpha",  0, 1, 0.02, 2
    /* StaticText " " */
    /* Slider     "Scale Cut-Off (X)",     "PBXWeapons_Weaponhud_boxW",       1, 250, 1
    Slider     "Scale Cut-Off (Y)",     "PBXWeapons_Weaponhud_boxH",       1, 250, 1 */
    /* Slider     "Scale Cut-Off (X)",     "PBXWeapons_WeaponModehud_boxW",   1, 250, 1
    Slider     "Scale Cut-Off (Y)",     "PBXWeapons_WeaponModehud_boxH",   1, 250, 1 */
    /* StaticText " " */
    
    StaticText " "
    
    // Reset
    Command "Reset HUD to Default", "resetcvar PBXWeapons_Weaponhud_x; resetcvar PBXWeapons_Weaponhud_y; resetcvar PBXWeapons_Weaponhud_scale; resetcvar PBXWeapons_Weaponhud_alpha; resetcvar PBXWeapons_Weaponhud_boxW; resetcvar PBXWeapons_Weaponhud_boxH; resetcvar PBXWeapons_WeaponModehud_x; resetcvar PBXWeapons_WeaponModehud_y; resetcvar PBXWeapons_WeaponModehud_scale; resetcvar PBXWeapons_WeaponModehud_alpha; resetcvar PBXWeapons_WeaponModehud_boxW; resetcvar PBXWeapons_WeaponModehud_boxH"
    
    StaticText " "

    StaticText "$PBXHud_Version"
}